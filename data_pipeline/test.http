### הגדרות משתנים
@aggregator_url = http://localhost:8000
@commander_url = http://localhost:8001

# ==========================================
# 1. שכבת הנתונים (State Aggregator)
# ==========================================
### קבלת תמונת מצב  - משיכה בודדת
# הערה לפולסטאק: לזרימת נתונים חלקה (10Hz),
# יש להתחבר ל-WebSocket בכתובת: ws://localhost:8000/ws
GET {{aggregator_url}}/api/state
Accept: application/json


# ==========================================
# 2. ניהול אירועים ומטרות (Target Control)
# ==========================================
### יצירת מטרה חדשה והזנקה אוטומטית (Auto-Scramble)
POST {{commander_url}}/new_target
Content-Type: application/json

{
    "lat": 31.750,
    "lon": 35.250
}


### ==========================================
# 3. ניהול כוחות ורחפנים (Deployment & RTB)
# ==========================================
### הזנקת רחפן מהבסיס (Manual Deploy)
# חובה לספק target_id כדי שהמוח ידע לאן לשייך אותו
POST {{commander_url}}/deploy_drone
Content-Type: application/json

{
    "role": "attack",
    "target_id": "TGT-C9DC"
}

### החזרת רחפן לבסיס (Recall / Return to Base)
# הרחפן יעבור לסטטוס RETURNING ויטוס חזרה לנ"צ של הבסיס
POST {{commander_url}}/recall_drone
Content-Type: application/json

{
    "drone_id": "DRN-10"
}


### ==========================================
# 4. עקיפה ושליטה ידנית (Manual Override)
# ==========================================
### שליחת רחפן לנ"צ ידני (Manual Move)
# מנתק את הרחפן מהמוח האוטומטי ומעביר אותו לסטטוס MANUAL
POST {{commander_url}}/manual_move
Content-Type: application/json

{
    "drone_id": "DRN-1",
    "lat": 31.755,
    "lon": 35.255,
    "alt": 150.0
}

### החזרת רחפן למצב אוטונומי (Resume Auto)
# מחזיר את הרחפן לסטטוס ACTIVE כדי שהמוח יחזור לנהל אותו
POST {{commander_url}}/resume_auto
Content-Type: application/json

{
    "drone_id": "DRN-1"
}


### ==========================================
# 5. ביצוע תקיפה (Strike Execution)
# ==========================================
### אישור אש ותקיפת מטרה (Engage)
POST {{commander_url}}/engage
Content-Type: application/json

{
    "action": "engage",
    "target_id": "TGT-1",
    "drone_id": "DRN-6"
}


### ==========================================
# 6. בדיקות תקינות (Health Check)
# ==========================================
GET {{commander_url}}/health