### הגדרות משתנים
@aggregator_url = http://localhost:8000
@commander_url = http://localhost:8001

# ==========================================
# 1. שכבת הנתונים (State Aggregator)
# ==========================================
### קבלת תמונת מצב עולמית (World State)
# נקודה זו משמשת את צוות הפולסטאק למשיכת הנתונים המעובדים של כלל הרכיבים.
# מחזירה JSON הכולל את מיקומי כל הרחפנים (תצפית ותקיפה), סטטוס טיסה, ומיקומים של מטרות.
GET {{aggregator_url}}/api/state
Accept: application/json


# ==========================================
# 2. ניהול אירועים ומטרות (Target Control)
# ==========================================
### יצירת מטרה חדשה והזנקה אוטומטית (Auto-Scramble)
# זוהי נקודת ההתנעה של האירוע.
# שליחת נ"צ לנקודה זו תגרום ל:
# א. הופעת מטרה בסימולטור המטרה במיקום שנבחר.
# ב. הזנקה אוטומטית של רחפן תצפית (Recon) ראשון מהבסיס לכיוון המטרה.
POST {{commander_url}}/new_target
Content-Type: application/json

{
    "lat": 31.750,
    "lon": 35.250
}

### ==========================================
# 3. ניהול כוחות ורחפנים (Deployment)
# ==========================================
### הזנקת רחפן נוסף מהבסיס (Manual Deploy)
# מאפשר לחייל להוסיף כוח אש או תצפית נוספת מעבר להזנקה האוטומטית.
# המערכת תבחר רחפן במצב "שינה" (SLEEP) ותעביר אותו למצב "פעיל" (ACTIVE).
# role: "recon" או "attack"
POST {{commander_url}}/deploy_drone
Content-Type: application/json

{
    "role": "attack"
}

### ==========================================
# 4. ביצוע תקיפה (Strike Execution)
# ==========================================
### אישור אש ותקיפת מטרה (Engage)
# הפקודה הקריטית ביותר. החייל בוחר רחפן ספציפי ומאשר לו לתקוף מטרה ספציפית.
# גורם לרחפן להוריד תחמושת, להטיל פצצה ולסימולטור המטרה לחשב נזק (BDA).
POST {{commander_url}}/engage
Content-Type: application/json

{
    "action": "engage",
    "target_id": "TGT-1",
    "drone_id": "DRN-6"
}

### ==========================================
# 5. בריאות המערכת (Health Checks)
# ==========================================
### בדיקת סטטוס שרת הקומנדר
GET {{commander_url}}/health
